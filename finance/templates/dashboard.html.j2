<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Finance: {{ period_label }}</title>
<style>
{{ tokens_css }}
  *{box-sizing:border-box}
  html{-webkit-text-size-adjust:100%}
  body{margin:0;background:var(--bg);color:var(--ink);font:15px/1.55 var(--sans);
       -webkit-font-smoothing:antialiased;}
  .wrap{max-width:940px;margin:0 auto;padding:32px 20px 72px;overflow-x:hidden;}
  h1{font-size:28px;line-height:1.1;margin:0 0 3px;letter-spacing:-.02em;text-wrap:balance;}
  h2{font-size:17px;font-weight:650;color:var(--ink);letter-spacing:-.01em;
     margin:40px 0 14px;padding-bottom:7px;border-bottom:1px solid var(--line);}
  .sub{color:var(--muted);font-size:13px;}
  .verdict{margin:16px 0 4px;font-size:16px;line-height:1.45;max-width:68ch;text-wrap:pretty;}
  .verdict b{font-weight:650}
  .banner{background:var(--accent-weak);border:1px solid var(--accent);color:var(--ink);
          padding:10px 14px;border-radius:10px;margin:16px 0;font-size:14px;}
  .pos{color:var(--green)} .neg{color:var(--red)} .muted{color:var(--muted)} .tiny{font-size:12px}
  .num{font-family:var(--mono);font-variant-numeric:tabular-nums;white-space:nowrap;}

  /* summary bar (KPIs) */
  .summary{display:flex;flex-wrap:wrap;border:1px solid var(--line);border-radius:14px;
           background:var(--card);margin-top:18px;overflow:hidden;}
  .cell{flex:1 1 140px;padding:15px 18px;border-left:1px solid var(--line);}
  .cell:first-child{border-left:none}
  .cell .k{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.05em;}
  .cell .v{font:600 25px/1.15 var(--mono);margin-top:7px;letter-spacing:-.01em;}
  .cell.key{background:var(--card2)} .cell.key .v{font-size:27px}

  /* net trend sparkline */
  .trend{display:flex;align-items:flex-end;gap:14px;margin-top:12px;padding:14px 18px;
         border:1px solid var(--line);border-radius:14px;background:var(--card);}
  .trend .k{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.05em;
            writing-mode:horizontal-tb;align-self:center;min-width:96px;}
  .spark{display:flex;align-items:flex-end;gap:8px;height:44px;flex:1;}
  .col{display:flex;flex-direction:column;align-items:center;justify-content:flex-end;gap:4px;flex:1;}
  .colbar{width:100%;max-width:26px;border-radius:3px 3px 0 0;min-height:2px;}
  .colbar.up{background:var(--green)} .colbar.down{background:var(--red)}
  .collab{font:11px var(--mono);color:var(--muted)}

  /* action strip */
  .action{display:flex;align-items:baseline;flex-wrap:wrap;gap:6px 16px;margin-top:12px;
          padding:14px 18px;border:1px solid var(--accent);border-radius:14px;background:var(--accent-weak);}
  .action .lbl{font-weight:650} .action .amt{font:700 24px/1 var(--mono);color:var(--accent);letter-spacing:-.01em;}
  .action .why{color:var(--muted);font-size:13px;margin-left:auto;}

  .pace{margin-top:12px;padding:12px 18px;border:1px solid var(--line);border-radius:12px;
        background:var(--card);font-size:14px;}

  /* tables */
  .tablewrap{overflow-x:auto;-webkit-overflow-scrolling:touch;}
  table{width:100%;border-collapse:collapse;font-size:14px;min-width:440px;}
  caption{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);}
  th,td{text-align:left;padding:9px 10px;border-bottom:1px solid var(--line);}
  thead th{color:var(--muted);font-weight:600;font-size:12px;}
  td.num,th.num{text-align:right}
  tbody tr{transition:background .12s ease}
  tbody tr:hover{background:var(--card2)}
  tr.green .rag{color:var(--green)} tr.amber .rag{color:var(--amber)} tr.red .rag{color:var(--red)}
  tr.red td:first-child{font-weight:600}

  /* panels */
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
  @media(max-width:640px){.grid2{grid-template-columns:1fr}}
  .panel{border:1px solid var(--line);border-radius:14px;background:var(--card);padding:6px 18px;}
  .phead{font-weight:650;font-size:13px;padding:12px 0 6px;}
  .row{display:flex;justify-content:space-between;align-items:baseline;gap:10px;
       padding:9px 0;border-bottom:1px solid var(--line);}
  .row:last-child{border-bottom:none}
  .bar{height:7px;background:var(--line);border-radius:5px;overflow:hidden;margin-top:6px;}
  .bar>i{display:block;height:100%;background:var(--accent);border-radius:5px;}
  .bar.green>i{background:var(--green)} .bar.amber>i{background:var(--amber)} .bar.red>i{background:var(--red)}
  .pill{font:600 11px var(--mono);padding:2px 8px;border-radius:20px;background:var(--card2);color:var(--muted);
        border:1px solid var(--line);}
  .pill.hot{background:color-mix(in srgb,var(--red) 16%,transparent);color:var(--red);border-color:transparent;}
  .empty{color:var(--muted);font-size:14px;padding:14px 0;}
  .foot{margin-top:44px;color:var(--muted);font-size:12px;border-top:1px solid var(--line);padding-top:14px;line-height:1.7;}
  code{font-family:var(--mono);background:var(--card2);padding:1px 6px;border-radius:6px;font-size:.9em;}
  @media (prefers-reduced-motion:reduce){*{transition:none!important;animation:none!important}}
</style>
</head>
<body>
<main class="wrap">

  <header>
    <h1>{{ period_label }}</h1>
    <div class="sub">{{ date_range }} · financial month (23rd–22nd) · {{ txn_count }} transactions</div>
    {% if banner %}<div class="banner">{{ banner }}</div>{% endif %}
    <p class="verdict">
      <b>{{ 'Surplus' if summary.net>=0 else 'Deficit' }} of {{ summary.net|abs|bhd }} BHD</b>
      on {{ summary.spend|bhd }} spend against {{ summary.income|bhd }} income{% if summary.savings_rate is not none %},
      a {{ summary.savings_rate }}% savings rate{% endif %}.{% if top_leak %}
      Biggest overspend: <b>{{ top_leak.category }}</b> at {{ top_leak.actual|bhd }} vs {{ top_leak.planned|bhd }} plan.{% endif %}
    </p>
  </header>

  <!-- Headline KPIs -->
  <div class="summary">
    <div class="cell"><div class="k">Income</div><div class="v pos">{{ summary.income|bhd }}</div></div>
    <div class="cell"><div class="k">Spend</div><div class="v">{{ summary.spend|bhd }}</div></div>
    <div class="cell key"><div class="k">Net</div>
      <div class="v {{ 'pos' if summary.net>=0 else 'neg' }}">{{ summary.net|bhd }}</div></div>
    <div class="cell"><div class="k">Savings rate</div>
      <div class="v {{ 'pos' if (summary.savings_rate or 0)>=0 else 'neg' }}">{{ summary.savings_rate if summary.savings_rate is not none else '—' }}%</div></div>
  </div>

  {% if net_trend and net_trend|length > 1 %}
  {% set peak = (net_trend|map(attribute='net')|map('abs')|max) or 1 %}
  <div class="trend">
    <div class="k">Net, last {{ net_trend|length }} months</div>
    <div class="spark">
      {% for t in net_trend %}
      <div class="col" title="{{ t.label }}: {{ t.net|bhd }}">
        <div class="colbar {{ 'up' if t.net>=0 else 'down' }}" style="height:{{ (2 + (t.net|abs) / peak * 36)|round(1) }}px"></div>
        <div class="collab">{{ t.label.split(' ')[0] }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <!-- Suggested action -->
  <div class="action">
    <span class="lbl">Suggested transfer this month</span>
    <span class="amt">{{ surplus.suggested_transfer|bhd }} BHD</span>
    <span class="why">net {{ surplus.net|bhd }} minus {{ surplus.school_set_aside|bhd }} school set-aside</span>
  </div>

  {% if pacing %}
  <div class="pace">
    <b>Pace:</b> day {{ pacing.day }}/{{ pacing.days }}, spent {{ pacing.spend_to_date|bhd }} so far,
    {% if pacing.closed %}final{% else %}on track for ~<b>{{ pacing.projected_spend|bhd }}</b>{% endif %}
    vs plan {{ pacing.plan_expense|bhd }}{% if pacing.last_spend is not none %} · last period {{ pacing.last_spend|bhd }}{% endif %}
    {% if pacing.on_track is not none %}<span class="pill {{ '' if pacing.on_track else 'hot' }}">{{ 'on track' if pacing.on_track else 'over pace' }}</span>{% endif %}
  </div>
  {% endif %}

  <h2>Plan vs actual</h2>
  <div class="tablewrap">
  <table>
    <caption>Planned versus actual amounts by category for {{ period_label }}</caption>
    <thead><tr><th scope="col">Category</th><th scope="col" class="num">Plan</th>
      <th scope="col" class="num">Actual</th><th scope="col" class="num">Variance</th><th scope="col">Status</th></tr></thead>
    <tbody>
    {% for r in income_rows %}
    <tr class="{{ r.rag|ragclass }}">
      <td>{{ r.category }} <span class="tiny muted">income</span></td>
      <td class="num">{{ r.planned|bhd }}</td><td class="num">{{ r.actual|bhd }}</td>
      <td class="num {{ 'pos' if r.variance>=0 else 'neg' }}">{{ r.variance|bhd }}</td>
      <td class="rag">{{ r.rag }}</td></tr>
    {% endfor %}
    {% for r in expense_rows %}
    <tr class="{{ r.rag|ragclass }}">
      <td>{{ r.category }}{% if r.section=='UNPLANNED' %} <span class="tiny muted">unplanned</span>{% endif %}</td>
      <td class="num">{{ r.planned|bhd }}</td><td class="num">{{ r.actual|bhd }}</td>
      <td class="num {{ 'neg' if r.variance>0 else 'pos' }}">{{ r.variance|bhd }}</td>
      <td class="rag">{{ r.rag }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
  </div>

  <h2>Where it went</h2>
  <div class="panel">
    {% for b in breakdown %}
    <div style="padding:9px 0;border-bottom:1px solid var(--line)">
      <div style="display:flex;justify-content:space-between;gap:10px">
        <span>{{ b.category or 'Uncategorised' }} <span class="tiny muted">({{ b.n }})</span></span>
        <span class="num">{{ b.spend|bhd }} <span class="muted tiny">{{ b.pct }}%</span></span>
      </div>
      <div class="bar"><i style="width:{{ b.pct }}%"></i></div>
    </div>
    {% else %}
    <div class="empty">No spending recorded this period.</div>
    {% endfor %}
  </div>

  <h2>Standing flags &amp; subscriptions</h2>
  <div class="grid2">
    <div class="panel">
      <div class="phead">Watch list</div>
      {% for f in flags %}
      <div class="row">
        <span style="font-weight:600">{{ f.category }}</span>
        <span class="num">{{ f.actual|bhd }}
          {% if f.vs_avg_pct is not none %}<span class="pill {{ 'hot' if f.vs_avg_pct>25 else '' }}">{{ '+' if f.vs_avg_pct>=0 else '' }}{{ f.vs_avg_pct }}% vs 3-mo</span>{% endif %}
        </span>
      </div>
      <div class="tiny muted" style="padding:0 0 8px">3-mo avg {{ f.avg_3mo|bhd }}{% if f.planned %} · plan {{ f.planned|bhd }}{% endif %}</div>
      {% endfor %}
    </div>
    <div class="panel">
      <div class="phead">Subscriptions ({{ sub_changes|length }}) <span class="tiny muted">hikes flagged</span></div>
      {% for s in sub_changes %}
      <div class="row" style="padding:7px 0">
        <span class="tiny">{{ s.merchant[:24] }}
          {% if s.status=='increased' %}<span class="pill hot">↑{{ s.delta_pct }}%</span>
          {% elif s.status=='new' %}<span class="pill">new</span>
          {% elif s.status=='gone' %}<span class="pill">gone</span>{% endif %}</span>
        <span class="num tiny">{{ s.amount|bhd }}</span></div>
      {% else %}
      <div class="empty">No subscription charges this period.</div>
      {% endfor %}
    </div>
  </div>

  <h2>Sinking &amp; savings</h2>
  <div class="grid2">
    <div class="panel" style="padding:16px 18px">
      <div class="k tiny muted" style="text-transform:uppercase;letter-spacing:.05em">{{ school.label }} · next due {{ school.next_due or '—' }}</div>
      <div class="num" style="font-size:22px;margin:8px 0">{{ school.target|bhd }}</div>
      <div class="tiny muted">set aside <b>{{ school.suggested_monthly|bhd }}</b>/mo for {{ school.months_to_due }} month(s) · paid this year {{ school.paid_this_year|bhd }}</div>
    </div>
    <div class="panel" style="padding:16px 18px">
      <div class="k tiny muted" style="text-transform:uppercase;letter-spacing:.05em">{{ emergency.label }} · target {{ emergency.target|bhd }}</div>
      <div class="num {{ 'pos' if emergency.pct and emergency.pct>=100 else '' }}" style="font-size:22px;margin:8px 0">{{ emergency.current|bhd }}</div>
      <div class="bar {{ 'green' if emergency.pct and emergency.pct>=100 else 'amber' }}"><i style="width:{{ [emergency.pct or 0,100]|min }}%"></i></div>
      <div class="tiny muted" style="margin-top:7px">{{ emergency.pct }}% of target · shortfall {{ emergency.shortfall|bhd }}{% if emergency.balances %}<br>Khaleeji {{ emergency.balances.get('khaleeji')|bhd }}, ila {{ emergency.balances.get('ila_account')|bhd }}{% endif %}</div>
    </div>
  </div>

  {% if forecast.rows %}
  <h2>Cash-flow forecast</h2>
  <div class="sub" style="margin-bottom:12px">Projected forward from {{ forecast.anchor_label }} balance {{ forecast.anchor_balance|bhd }}, if you follow the plan.{% if forecast.low %} Low point: <b>{{ forecast.low.label }}</b> at {{ forecast.low.projected_balance|bhd }}.{% endif %}</div>
  <div class="tablewrap">
  <table>
    <caption>Projected end-of-period balances following the plan</caption>
    <thead><tr><th scope="col">Period</th><th scope="col" class="num">Planned net</th>
      <th scope="col" class="num">Projected balance</th><th scope="col"></th></tr></thead>
    <tbody>
    {% for r in forecast.rows %}
    <tr class="{% if forecast.low and r.period_id==forecast.low.period_id %}red{% endif %}">
      <td>{{ r.label }}{% if r.school_due %} 🎓{% endif %}</td>
      <td class="num {{ 'pos' if r.planned_net>=0 else 'neg' }}">{{ r.planned_net|bhd }}</td>
      <td class="num">{{ r.projected_balance|bhd }}</td>
      <td class="rag">{% if forecast.low and r.period_id==forecast.low.period_id %}⬇ low{% endif %}</td></tr>
    {% endfor %}
    </tbody>
  </table>
  </div>
  {% endif %}

  <h2>Needs review: {{ uncat_count }} uncategorised ({{ uncat_pct }}%)</h2>
  <div class="sub" style="margin-bottom:12px">Resolve with <code>finance review</code>. Naming an IBAN once teaches it for every month.</div>
  {% if uncategorised %}
  <div class="tablewrap">
  <table>
    <caption>Largest uncategorised counterparties and merchants</caption>
    <thead><tr><th scope="col">Counterparty / merchant</th><th scope="col" class="num">Count</th><th scope="col" class="num">Amount</th></tr></thead>
    <tbody>
    {% for u in uncategorised %}
    <tr><td>{{ u.who }} {% if u.is_iban %}<span class="tiny muted">IBAN</span>{% endif %}</td>
        <td class="num">{{ u.n }}</td><td class="num">{{ u.amt|bhd }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
  </div>
  {% else %}
  <div class="empty">Nothing to review. Everything is categorised. 🎉</div>
  {% endif %}

  <div class="foot">Generated {{ generated_at }} · <code>finance run</code> · SQLite is the source of truth.<br>
    BHD, financial month 23rd–22nd. Status: 🟢 within plan · 🟡 up to 15% over · 🔴 more than 15% over.</div>
</main>
</body>
</html>
